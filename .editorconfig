# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs
# editorconfig.org

root = true

# Universal settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
# https://peps.python.org/pep-0008/#indentation
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# Misc files
[*.{ps1xml,props,xml,yaml,json}]
indent_style = space
indent_size = 2

# Markdown files (for documentation)
[*.md]
trim_trailing_whitespace = false  # Allow trailing whitespace in Markdown, which can denote line breaks
indent_size = 2
